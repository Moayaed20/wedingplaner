    {
      "name": "الصالات (Halls) - الإضافة/الحذف للأدمن فقط",
      "item": [
        {
          "name": "كل الصالات (عامة)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/halls",
              "host": ["{{base_url}}"],
              "path": ["halls"],
              "query": [
                { "key": "city", "value": "دمشق", "disabled": true },
                { "key": "minCapacity", "value": "100", "disabled": true },
                { "key": "maxCapacity", "value": "300", "disabled": true },
                { "key": "maxPrice", "value": "2000", "disabled": true },
                { "key": "rating", "value": "4", "disabled": true }
